import numpy as np 
import pandas as pd 
import matplotlib.pyplot as plt


x=np.array([1,2,3,4,5])
y=np.array([4,5,7,9,11])

m=0
b=0

lr=0.01
n=len(x)

for i in range(1000):
    y_pred=m*x+b
    dm =(-2/n)*np.sum(x*(y-y_pred))
    db=(-2/n)*np.sum((y-y_pred))
    m=m-lr*dm
    b=b-lr*db
  
print(f"slope m ={m}   b is {b}")  
plt.scatter(x,y)
plt.plot(x,m*x+b)
plt.show()
